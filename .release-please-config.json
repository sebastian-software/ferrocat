{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": false,
  "plugins": [
    {
      "type": "cargo-workspace",
      "merge": false,
      "updateAllPackages": true
    },
    {
      "type": "linked-versions",
      "groupName": "ferrocat",
      "merge": true,
      "components": [
        "ferrocat",
        "ferrocat-po",
        "ferrocat-icu"
      ]
    }
  ],
  "packages": {
    "crates/ferrocat": {
      "release-type": "rust",
      "package-name": "ferrocat",
      "component": "ferrocat",
      "extra-files": [
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.package.version"
        },
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.dependencies[\"ferrocat\"].version"
        },
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.dependencies[\"ferrocat-po\"].version"
        },
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.dependencies[\"ferrocat-icu\"].version"
        },
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.dependencies[\"ferrocat-conformance\"].version"
        },
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.dependencies[\"ferrocat-bench\"].version"
        }
      ]
    },
    "crates/ferrocat-po": {
      "release-type": "rust",
      "package-name": "ferrocat-po",
      "component": "ferrocat-po"
    },
    "crates/ferrocat-icu": {
      "release-type": "rust",
      "package-name": "ferrocat-icu",
      "component": "ferrocat-icu"
    }
  }
}
